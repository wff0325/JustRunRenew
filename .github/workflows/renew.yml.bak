name: JRM-Renew

on:
  workflow_dispatch:
  schedule:
    - cron: '0 */48 * * *'   # 每 48 小时触发一次（有效期 ~3 天）

jobs:
  run_jrm_renew:
    runs-on: ubuntu-latest
    
    # 1. 必须赋予写入权限
    permissions:
      contents: write

    steps:
      # =========================================================
      # ⚠️ 新增：必须先检出当前仓库，否则无法提交 time.txt
      # =========================================================
      - name: 📥 检出当前仓库
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: 📥 下载私库脚本
        uses: actions/checkout@v4
        with:
          repository: ${{ github.repository_owner }}/Renew-Private
          token: ${{ secrets.PRIVATE_REPO_TOKEN }}
          path: private

      - name: 📂 移动脚本到工作目录
        run: mv private/justrunmy_renew.py justrunmy_renew.py

      - name: 🐍 设置 Python
        uses: actions/setup-python@v6
        with:
          python-version: '3.x'

      - name: 🛡️ 启动 GOST 代理转发
        if: ${{ env.GOST_PROXY != '' }}
        env:
          GOST_PROXY: ${{ secrets.GOST_PROXY }}
        run: |
          VERSION=$(curl -s https://api.github.com/repos/ginuerzh/gost/releases/latest | grep '"tag_name"' | cut -d'"' -f4 | tr -d 'v')
          echo "📦 GOST 版本: $VERSION"
          wget -q "https://github.com/ginuerzh/gost/releases/download/v${VERSION}/gost_${VERSION}_linux_amd64.tar.gz"
          tar -xzf "gost_${VERSION}_linux_amd64.tar.gz"
          chmod +x gost
          nohup ./gost -L http://:8080 -F "$GOST_PROXY" > gost.log 2>&1 &
          sleep 3
          IP=$(curl -s -x http://127.0.0.1:8080 https://api.ipify.org)
          IP_MASKED=$(echo "$IP" | sed 's/\([0-9]*\.[0-9]*\.[0-9]*\.\)[0-9]*/\1xx/')
          echo "✅ GOST 已启动，出口IP确认：$IP_MASKED"

      - name: 🛠️ 安装系统依赖
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            google-chrome-stable \
            xvfb \
            x11-utils \
            xdotool \
            scrot

      - name: 🐍 安装 Python 依赖
        run: |
          pip install seleniumbase
          seleniumbase install chromedriver

      - name: 🚀 运行脚本
        env:
          PYTHONIOENCODING: utf-8
          JRM_ACCOUNT: ${{ secrets.JRM_ACCOUNT }}
          GOST_PROXY: ${{ secrets.GOST_PROXY }}
          TG_BOT: ${{ secrets.TG_BOT }}
        run: |
          xvfb-run --auto-servernum --server-args="-screen 0 1920x1080x24" python justrunmy_renew.py

      - name: 📸 上传截图
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: debug-screenshots
          path: "*.png"

      # =========================================================
      # ⏱️ 新增：提交 time.txt 到仓库
      # =========================================================
      - name: ⏱️ Commit time.txt to repo
        if: always()
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"

          CURRENT_TIME=$(date +'%Y-%m-%d %H:%M:%S')
          echo "最后续期运行时间：$CURRENT_TIME" > time.txt

          git add time.txt
          
          if git diff --cached --quiet; then
            echo "没有内容变化，跳过提交。"
          else
            git commit -m "⏱️ KeepAlive: $CURRENT_TIME"
            git pull --rebase origin ${{ github.ref_name }}
            git push origin HEAD:${{ github.ref_name }}
          fi
